      ]
    },
    {
      "type": "row",
      "title": "Latency",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 },
      "id": 101
    },
    {
      "type": "timeseries",
      "title": "Latency by Quantile (µs)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 7 },
      "id": 5,
      "fieldConfig": {
        "defaults": {
          "unit": "µs",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 5,
            "showPoints": "never",
            "lineWidth": 2
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max", "lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "benchmark_live_latency_microseconds{protocol=~\"$protocol\", quantile=~\"p50|p95|p99|p999\"}",
          "legendFormat": "{{protocol}} {{quantile}}"
        }
      ]
    },
